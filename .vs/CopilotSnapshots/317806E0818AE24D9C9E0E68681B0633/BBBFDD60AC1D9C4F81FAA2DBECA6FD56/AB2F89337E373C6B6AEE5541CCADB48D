<!DOCTYPE html>
<html lang="es"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>EcoMarket - Publicar</title>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css"><link rel="stylesheet" href="css/app.css"></head><body>
<nav class="navbar"><div class="container nav-inner">
  <a href="/" class="nav-brand"><div class="logo-icon"><i class="fas fa-bolt"></i></div><span>Eco<strong>Market</strong></span></a>
</div></nav>
<div class="publish-page">
  <h1 data-i18n="pub.title">Publicar producto</h1>
  <div class="publish-card">
    <div id="pubAlert" class="alert"></div>
    <form onsubmit="handlePublish(event)">
      <div class="form-group"><label data-i18n="pub.prodTitle">Título</label><input type="text" name="prodTitle" required placeholder="Ej: Tesla Model 3 2023 - Autonomía 500km"></div>
      <div class="form-row">
        <div class="form-group"><label data-i18n="pub.price">Precio (USD)</label><input type="number" name="price" required min="1" step="0.01"></div>
        <div class="form-group"><label data-i18n="pub.category">Categoría</label>
          <select name="category" required>
            <option value="autos" data-i18n="pub.catAutos">Autos eléctricos</option><option value="motos" data-i18n="pub.catMotos">Motos eléctricas</option>
            <option value="bicicletas" data-i18n="pub.catBikes">Bicicletas eléctricas</option><option value="scooters" data-i18n="pub.catScooters">Scooters</option>
            <option value="repuestos" data-i18n="pub.catParts">Repuestos</option><option value="accesorios" data-i18n="pub.catAccs">Accesorios</option>
          </select>
        </div>
      </div>
      <div class="form-row">
        <div class="form-group"><label data-i18n="pub.condition">Condición</label>
          <select name="condition"><option value="new" data-i18n="pub.new">Nuevo</option><option value="used" data-i18n="pub.used">Usado</option></select>
        </div>
        <div class="form-group"><label data-i18n="pub.brand">Marca</label><input type="text" name="brand" placeholder="Ej: Tesla, BYD, Xiaomi"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label data-i18n="pub.model">Modelo</label><input type="text" name="model"></div>
        <div class="form-group"><label data-i18n="pub.year">Año</label><input type="number" name="year" min="2000" max="2030"></div>
      </div>
      <div class="form-row">
        <div class="form-group"><label data-i18n="pub.range">Autonomía (km)</label><input type="text" name="range_km" placeholder="Ej: 500"></div>
        <div class="form-group"><label data-i18n="pub.battery">Batería</label><input type="text" name="battery" placeholder="Ej: 60 kWh Litio"></div>
      </div>
      <div class="form-group"><label data-i18n="pub.location">Ubicación</label><input type="text" name="location" placeholder="Ej: Buenos Aires, Argentina"></div>
      <div class="form-group"><label data-i18n="pub.desc">Descripción</label><textarea name="description" rows="5" placeholder="Describí tu producto en detalle..."></textarea></div>
      <button type="submit" class="btn btn-primary" style="width:100%;justify-content:center" data-i18n="pub.btn">Publicar</button>
    </form>
  </div>
</div>
<script src="js/app.js"></script>
<script>if(!getUser())location.href='login.html';</script>
</body></html>
